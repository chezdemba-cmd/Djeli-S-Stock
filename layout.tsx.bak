:root{--ink:#17221f;--muted:#6c7773;--green:#173f35;--green-2:#246452;--cream:#f5f2e9;--gold:#d7a83f;--line:#e7e8e3;--white:#fff;--danger:#c7463d;--blue:#376a91}*{box-sizing:border-box}body{margin:0;background:#f7f8f5;color:var(--ink);font-family:Arial,Helvetica,sans-serif}.app-shell{min-height:100vh}.sidebar{position:fixed;inset:0 auto 0 0;width:250px;background:var(--green);color:white;padding:26px 18px;display:flex;flex-direction:column;z-index:20}.brand{display:flex;gap:11px;align-items:center;padding:0 8px 26px}.brand-mark{width:42px;height:42px;border:1px solid rgba(255,255,255,.55);border-radius:50% 45% 50% 42%;display:grid;place-items:center;font-family:Georgia,serif;font-size:25px;color:#efd17f}.brand strong,.brand span{display:block;letter-spacing:2px}.brand span{font-size:10px;color:#d7bc6c;margin-top:3px}.depot{display:flex;gap:9px;align-items:center;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);padding:12px;border-radius:12px;margin-bottom:26px}.depot div{min-width:0;flex:1}.depot span,.user-card span{display:block;font-size:10px;color:#b8cbc5;margin-bottom:4px}.depot strong{font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.sidebar nav{display:grid;gap:6px}.sidebar nav button{border:0;background:transparent;color:#c7d5d0;padding:12px;border-radius:9px;text-align:left;display:flex;align-items:center;gap:12px;font-size:14px;cursor:pointer}.sidebar nav button:hover,.sidebar nav button.active{background:#f2e3b5;color:#183f35;font-weight:700}.user-card{margin-top:auto;border-top:1px solid rgba(255,255,255,.15);padding:19px 7px 0;display:flex;gap:10px;align-items:center}.avatar{width:36px;height:36px;border-radius:50%;background:#d9b75c;color:#173f35;display:grid;place-items:center;font-weight:bold;font-size:12px}.user-card strong{font-size:12px;display:block}.content{margin-left:250px;min-height:100vh;padding:0 42px 50px}.content header{height:100px;display:flex;justify-content:space-between;align-items:center}.content header p{margin:0 0 5px;color:var(--muted);font-size:12px}.content header h1{margin:0;font-family:Georgia,serif;font-size:27px}.header-actions{display:flex;gap:12px}.icon-button{border:1px solid var(--line);background:white;width:42px;height:42px;border-radius:10px;position:relative}.icon-button i{position:absolute;width:7px;height:7px;background:#c8473d;border-radius:50%;right:9px;top:8px}.primary,.welcome button{border:0;background:var(--green);color:white;border-radius:9px;padding:12px 17px;display:inline-flex;gap:8px;align-items:center;justify-content:center;font-weight:700;cursor:pointer}.welcome{background:linear-gradient(105deg,#173f35,#28624f);border-radius:18px;padding:26px 30px;color:white;display:flex;align-items:center;justify-content:space-between;box-shadow:0 12px 24px rgba(23,63,53,.12);position:relative;overflow:hidden}.welcome:after{content:"D";position:absolute;right:120px;top:-75px;font-family:Georgia,serif;font-size:210px;color:rgba(255,255,255,.045);transform:rotate(-12deg)}.welcome span{font-size:10px;letter-spacing:2px;color:#e2c875}.welcome h2{font:25px Georgia,serif;margin:9px 0}.welcome p{margin:0;color:#cbdad5;font-size:13px}.welcome button{background:#f0d995;color:#173f35;z-index:1}.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin:18px 0}.metric{background:white;border:1px solid var(--line);border-radius:14px;padding:18px;display:flex;gap:12px;align-items:flex-start}.metric-icon{width:40px;height:40px;border-radius:10px;display:grid;place-items:center;flex:none}.metric-icon svg{width:19px}.metric-icon.green{background:#e7f1ed;color:#25604e}.metric-icon.gold{background:#fbf1d8;color:#9b6e0d}.metric-icon.blue{background:#e9f0f5;color:#376a91}.metric-icon.red{background:#fae9e7;color:#b8443a}.metric span,.metric small{display:block;color:var(--muted);font-size:11px}.metric strong{display:block;font:19px Georgia,serif;margin:5px 0 7px}.grid-two{display:grid;grid-template-columns:1.15fr .85fr;gap:18px}.panel{background:white;border:1px solid var(--line);border-radius:14px}.panel-title{height:56px;padding:0 19px;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between}.panel-title h3{font:17px Georgia,serif}.panel-title button{border:0;background:none;color:#426c60;font-size:11px;display:flex;align-items:center;cursor:pointer}.movement-list{padding:4px 18px}.movement{display:flex;align-items:center;gap:12px;padding:13px 0;border-bottom:1px solid #eff0ed}.movement:last-child{border:0}.move-icon{width:37px;height:37px;border-radius:9px;display:grid;place-items:center}.move-icon svg{width:17px}.move-icon.in{background:#e8f3ed;color:#277251}.move-icon.out{background:#fbede8;color:#b5533f}.move-main{flex:1}.move-main strong,.move-main span,.qty span{display:block}.move-main strong{font-size:12px}.move-main span{font-size:10px;color:var(--muted);margin-top:5px}.qty{text-align:right;font-weight:bold;font-size:13px}.qty span{font-size:9px;font-weight:normal;margin-top:5px}.qty.in{color:#287252}.qty.out{color:#ad4c3e}.alerts{padding:8px 18px}.alert-row{padding:15px 0;border-bottom:1px solid #eff0ed;display:flex;justify-content:space-between}.alert-row:last-child{border:0}.alert-row strong,.alert-row span{display:block}.alert-row strong{font-size:12px}.alert-row span{font-size:10px;color:var(--muted);margin-top:5px}.alert-row>div:last-child{text-align:right;color:var(--danger)}.page-panel{padding:20px}.toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}.toolbar h2{font:22px Georgia,serif;margin:0 0 5px}.toolbar p{color:var(--muted);margin:0;font-size:12px}.search{width:min(440px,65%);height:42px;border:1px solid var(--line);border-radius:10px;display:flex;align-items:center;gap:9px;padding:0 12px}.search input{border:0;outline:0;width:100%;font-size:13px}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse;text-align:left}th{font-size:10px;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);padding:12px;border-bottom:1px solid var(--line)}td{padding:15px 12px;border-bottom:1px solid #eff0ed;font-size:12px}td span{display:block;color:var(--muted);font-size:10px;margin-top:4px}.status{display:inline-block;padding:6px 9px;border-radius:20px;font-weight:bold}.status.ok{background:#e8f3ed;color:#25704f}.status.danger{background:#fbe9e7;color:#b6443b}.empty{text-align:center;padding:70px 25px}.empty-icon{width:65px;height:65px;border-radius:18px;background:#e8f1ed;color:var(--green);display:grid;place-items:center;margin:auto}.empty h2{font:25px Georgia,serif}.empty p{color:var(--muted);max-width:450px;margin:0 auto 22px;line-height:1.6}.modal-backdrop{position:fixed;inset:0;background:rgba(12,30,25,.55);z-index:30;display:grid;place-items:center;padding:18px}.modal{background:white;border-radius:18px;padding:28px;width:min(610px,100%);position:relative;box-shadow:0 30px 80px rgba(0,0,0,.25)}.modal-close{position:absolute;right:18px;top:18px;border:0;background:#f3f4f1;width:34px;height:34px;border-radius:9px;display:grid;place-items:center}.modal-heading{display:flex;gap:13px;align-items:center;margin-bottom:22px}.modal-heading h2{font:23px Georgia,serif;margin:0 0 5px}.modal-heading p{margin:0;color:var(--muted);font-size:12px}.modal-symbol{width:46px;height:46px;border-radius:12px;background:#e7f0ec;color:var(--green);display:grid;place-items:center}.modal form{display:grid;grid-template-columns:1fr 1fr;gap:14px}.modal label{font-size:11px;font-weight:bold}.modal input,.modal select{display:block;width:100%;height:42px;border:1px solid #dfe2dd;border-radius:9px;margin-top:7px;padding:0 11px;background:white}.wide{grid-column:1/-1}.form-actions{display:flex;justify-content:flex-end;gap:10px;margin-top:7px}.form-actions button{padding:11px 17px;border:0;border-radius:9px;font-weight:bold}.nav-close,.menu-button{display:none}.full{padding:0 5px}
@media(max-width:1050px){.metrics{grid-template-columns:1fr 1fr}.grid-two{grid-template-columns:1fr}.content{padding:0 24px 40px}}
@media(max-width:760px){.sidebar{transform:translateX(-100%);transition:.25s}.sidebar.open{transform:translateX(0);box-shadow:20px 0 50px rgba(0,0,0,.2)}.nav-close{display:grid;position:absolute;right:14px;top:15px;border:0;background:rgba(255,255,255,.1);color:white;width:34px;height:34px;place-items:center;border-radius:8px}.content{margin:0;padding:0 14px 35px}.content header{height:82px}.menu-button{display:grid;border:0;background:white;width:40px;height:40px;border-radius:10px;place-items:center;margin-right:10px}.content header>div:nth-child(2){flex:1}.content header h1{font-size:21px}.content header p{display:none}.header-actions .icon-button{display:none}.header-actions .primary{font-size:0;padding:11px}.header-actions .primary svg{margin:0}.welcome{padding:23px;display:block}.welcome h2{font-size:21px}.welcome button{margin-top:18px}.metrics{grid-template-columns:1fr 1fr;gap:10px}.metric{padding:13px;display:block}.metric-icon{margin-bottom:10px}.metric strong{font-size:16px}.grid-two{gap:12px}.toolbar{align-items:flex-start}.search{width:70%}th:nth-child(2),td:nth-child(2),th:nth-child(4),td:nth-child(4){display:none}.modal form{grid-template-columns:1fr}.modal label,.wide{grid-column:1}.modal{padding:24px 18px}.form-actions{grid-column:1}.welcome:after{display:none}}
@media(max-width:430px){.metrics{grid-template-columns:1fr}.metric{display:flex}.metric-icon{margin:0}.welcome h2{font-size:19px}.content header h1{font-size:19px}}
